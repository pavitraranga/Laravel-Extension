{
  "name": "laravel-project-creator",
  "displayName": "Laravel Project Creator",
  "description": "Create Laravel projects dynamically from a sidebar extension",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./src/extension.js",
  "activationEvents": [
    "onView:laravelProjectCreator.sidebarView"
  ],
  "contributes": {
    "commands": [
      {
        "command": "laravelProjectCreator.openPanel",
        "title": "Laravel Creator: Open Panel"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "laravelProjectCreatorContainer",
          "title": "Laravel Creator",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "laravelProjectCreatorContainer": [
        {
          "type": "webview",
          "id": "laravelProjectCreator.sidebarView",
          "name": "Project Creator"
        }
      ]
    }
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x"
  }
}
